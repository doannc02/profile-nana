<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HLV Nguyễn Ngọc Anh</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
* { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

body {
  margin: 0;
  font-family: 'Inter', sans-serif;
  color: white;

  background:
    radial-gradient(circle at 50% -20%, #ff2d95 0%, transparent 40%),
    linear-gradient(180deg, #d81b60 0%, #6a0f3a 40%, #0d0d0d 80%, #000 100%);

  display: flex;
  justify-content: center;
}

/* TOPBAR */
.topbar {
  position: fixed;
  top: 12px;
  left: 50%;
  transform: translateX(-50%);
  width: calc(100% - 24px);
  max-width: 420px;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(12px);
  border-radius: 14px;
  padding: 10px 14px;
  display: flex;
  justify-content: space-between;
  color: #000;
  font-weight: 600;
}

/* CONTAINER */
.container {
  max-width: 420px;
  padding: 90px 16px 40px;
  text-align: center;
}

/* AVATAR */
.avatar {
  position: relative;
  width: 90px;
  height: 90px;
  margin: auto;
  cursor: pointer;
}

.avatar img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3px solid white;
  object-fit: cover;
  object-position: center 20%;
  transform: scale(1.3);
}

.avatar::before {
  content: "";
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  background: linear-gradient(45deg, #ff2d95, #ff7ad9);
  filter: blur(10px);
  z-index: -1;
}

.badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: #1da1f2;
  border-radius: 50%;
  padding: 4px;
}

/* TEXT */
.name { font-size: 20px; font-weight: 700; margin-top: 10px; }
.bio { font-size: 14px; opacity: 0.85; }

/* SOCIAL */
.social {
  display: flex;
  justify-content: center;
  gap: 28px;
  margin: 20px 0;
}

.icon {
  width: 26px;
  height: 26px;
  cursor: pointer;
}

/* CARD */
.card {
  background: #f3f3f3;
  border-radius: 999px;
  padding: 10px 14px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 12px;
  color: #000;
  cursor: pointer;
  transition: 0.2s;
}

.card:active { transform: scale(0.96); }

.card img {
  width: 44px;
  height: 44px;
  border-radius: 50%;
}

.text { text-align: left; }
.title { font-size: 13px; font-weight: 600; }
.desc { font-size: 11px; color: #666; }

/* MODAL */
.modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.85);
  display: none;
  justify-content: center;
  align-items: center;
}

.modal iframe, .modal img {
  width: 90%;
  max-width: 400px;
  border-radius: 12px;
}

/* QR */
.qr img {
  width: 120px;
  margin-top: 20px;
  border-radius: 10px;
}
</style>
</head>

<body>

<div class="topbar">
  <div>Beacons</div>
  <div>Try free</div>
</div>

<div class="container">

  <!-- AVATAR -->
  <div class="avatar" id="avatar">
    <img src="na.jpeg">
    <div class="badge">✔</div>
  </div>

  <div class="name">HLV Nguyễn Ngọc Anh</div>
  <div class="bio">Cơ sở Kim Giang • Võ Đường CNK Hà Đông</div>

  <!-- SOCIAL -->
  <div class="social">
    <svg class="icon" data-link="https://www.tiktok.com/@connhikhuchadong" viewBox="0 0 24 24" fill="white">
      <path d="M19 7.5a7 7 0 0 1-4-1.3V14a5 5 0 1 1-5-5h.5v2H10a3 3 0 1 0 3 3V2h2a5 5 0 0 0 4 3.5z"/>
    </svg>

    <svg class="icon" data-link="https://www.facebook.com/share/1G6diwqHoq/?mibextid=wwXIfr" viewBox="0 0 24 24" fill="white">
      <path d="M22 12a10 10 0 1 0-11.5 9.9v-7h-2v-3h2V9.5c0-2 1.2-3.1 3-3.1z"/>
    </svg>

    <svg class="icon" data-phone="0326462544" viewBox="0 0 24 24" fill="white">
      <path d="M6.6 10.8a15 15 0 0 0 6.6 6.6"/>
    </svg>
  </div>

  <!-- CARDS -->
  <div class="card" data-action="gallery">
    <img src="https://cdn-icons-png.flaticon.com/512/1829/1829586.png">
    <div class="text">
      <div class="title">VIDEO BIỂU DIỄN CNK</div>
      <div class="desc">Xem kỹ thuật</div>
    </div>
  </div>

  <div class="card" data-zalo="0326462544">
    <img src="https://upload.wikimedia.org/wikipedia/commons/9/91/Icon_of_Zalo.svg">
    <div class="text">
      <div class="title">LIÊN HỆ ZALO</div>
      <div class="desc">0326.462.544</div>
    </div>
  </div>

  <div class="card" data-action="form">
    <img src="https://cdn-icons-png.flaticon.com/512/2921/2921222.png">
    <div class="text">
      <div class="title">ĐĂNG KÝ LỚP HỌC</div>
      <div class="desc">Tham gia CNK</div>
    </div>
  </div>

  <div class="card" data-link="https://www.facebook.com/share/1G6diwqHoq/?mibextid=wwXIfr">
    <img src="https://cdn-icons-png.flaticon.com/512/733/733547.png">
    <div class="text">
      <div class="title">FACEBOOK</div>
      <div class="desc">Hoạt động võ đường</div>
    </div>
  </div>

  <!-- QR -->
  <div class="qr">
    <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://YOUR_LINK_HERE">
  </div>

</div>

<!-- VIDEO MODAL -->
<div class="modal" id="videoModal">
  <iframe id="videoFrame" src=""></iframe>
</div>

<!-- FORM MODAL -->
<div class="modal" id="formModal">
  <iframe id="formFrame" src=""></iframe>
</div>

<!-- AVATAR MODAL -->
<div class="modal" id="imgModal">
  <img src="na.jpeg">
</div>

<script>
document.addEventListener("click", function(e) {
  const el = e.target.closest("[data-link],[data-phone],[data-zalo],[data-action]");
  if (!el) return;

  setTimeout(() => {
    if (el.dataset.link) window.open(el.dataset.link);
    if (el.dataset.phone) location.href = "tel:" + el.dataset.phone;
    if (el.dataset.zalo) window.open("https://zalo.me/" + el.dataset.zalo);

    if (el.dataset.action === "gallery") {
      videoFrame.src = "https://www.youtube.com/embed/dQw4w9WgXcQ";
      videoModal.style.display = "flex";
    }

    if (el.dataset.action === "form") {
      formFrame.src = "https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform";
      formModal.style.display = "flex";
    }
  }, 100);
});

// modal close
document.querySelectorAll(".modal").forEach(m => {
  m.noscript = () => {
    m.style.display = "none";
    m.querySelectorAll("iframe").forEach(i => i.src = "");
  };
});

// avatar preview
avatar.noscript = () => imgModal.style.display = "flex";
</script>

</body>
</html>
